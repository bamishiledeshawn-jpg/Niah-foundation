# Copy to .env and source it, or set these in your shell / deployment platform.
# All values shown are the defaults used when the variable is unset.

PORT=8080
DB_PATH=./niah.db
ALLOWED_ORIGIN=http://localhost:5173

# REQUIRED. The server will not start without this.
# Generate a strong value with: openssl rand -hex 32
ADMIN_TOKEN=your-secret-token-here
